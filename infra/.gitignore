# Local state and plan files — never commit, may contain secrets.
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# Provider plugins and modules cache.
.terraform/
.terraform.tfstate.lock.info

# Variable files often contain account-specific or sensitive values.
# An example.tfvars (without secrets) can be committed to show the shape.
*.tfvars
*.tfvars.json
!example.tfvars

# Override files — local-only customizations.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Patched index.html generated by the deploy snippet in README.md before
# upload to S3. Source of truth is ../app/static/index.html.
dist/

# Note: .terraform.lock.hcl IS committed (locks provider versions).
